    {"id":"tool_email","name":"Tool Email Manager","type":"@n8n/n8n-nodes-langchain.toolWorkflow","typeVersion":2.2,"position":[1900,50],"parameters":{"description":"Agente de email. Use para: ler, redigir, organizar emails, criar filtros, resumir caixa de entrada, agendar envios.","source":"database","workflowId":{"__rl":true,"value":"vS4xNI0ay4TRbdKe","mode":"list","cachedResultName":"Sub-Agente Email Manager"},"workflowInputs":{"mappingMode":"defineBelow","value":{"query":"={{ $fromAI('query', 'A tarefa ou pergunta para o agente de email', 'string') }}"},"schema":[{"id":"query","displayName":"query","required":true,"defaultMatch":false,"display":true,"type":"string","canBeUsedToMatch":true}]},"toolDescription":"Agente especialista em emails. Use para: ler emails, redigir respostas profissionais, organizar caixa de entrada, criar filtros e etiquetas, resumir emails importantes, agendar envios e qualquer tarefa de gerenciamento de email."}},
