        "responseBody": "={{ JSON.stringify({ status: 'ok', message: 'Seus dados foram removidos com sucesso conforme a Lei 13.709/2018 (LGPD). Protocolo: ' + new Date().getTime() }) }}",
        "options": {
          "responseCode": 200
        }
      }
    }
