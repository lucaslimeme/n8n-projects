        }
      }
    },
    {
      "id": "w4n10",
      "name": "Notificar Equipe",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1680,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.telegram.org/bot' + $env.TELEGRAM_BOT_TOKEN + '/sendMessage' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ chat_id: $env.TELEGRAM_CHAT_ID, text: 'LGPD - Solicitacao de exclusao processada!\\nTelefone anonimizado: ' + $('Anonimizar Lead').first().json._phone + '\\nData: ' + new Date().toISOString() + '\\nDados substituidos por REMOVIDO conforme Lei 13.709/2018.', parse_mode: 'HTML' }) }}",
        "options": {
          "timeout": 10000
        }
      }
    },
    {
      "id": "w4n11",
      "name": "Responder 200",
